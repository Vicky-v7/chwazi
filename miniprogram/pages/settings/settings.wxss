/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background-color: #0a0a0a;
  color: #ffffff;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #0a0a0a;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #ffffff;
}

.nav-placeholder {
  width: 80rpx;
}

/* 内容区 */
.content {
  padding: 24rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
}

/* 分区标题 */
.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 模式列表 */
.mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.mode-item.active {
  background-color: rgba(91, 141, 239, 0.15);
  border-color: rgba(91, 141, 239, 0.35);
}

.mode-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.mode-info {
  flex: 1;
}

.mode-name {
  font-size: 30rpx;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

.mode-check {
  font-size: 36rpx;
  color: #5B8DEF;
  font-weight: bold;
  margin-left: 16rpx;
}

/* 计数器 */
.counter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 28rpx 0;
}

.counter-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.counter-btn text {
  font-size: 48rpx;
  color: #ffffff;
  line-height: 1;
}

.counter-btn.disabled {
  opacity: 0.3;
}

.counter-value {
  font-size: 72rpx;
  font-weight: 300;
  color: #5B8DEF;
  min-width: 80rpx;
  text-align: center;
}

/* 开关设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  margin-bottom: 12rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #ffffff;
}

/* 反馈按钮（重写 button 默认样式） */
.feedback-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  margin-bottom: 12rpx;
  margin-top: 12rpx;
  border: none;
  line-height: normal;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.feedback-item::after {
  border: none;
}

.feedback-hover {
  background-color: rgba(255, 255, 255, 0.08) !important;
}

.feedback-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1;
}

/* 关于 */
.about-text {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 16rpx 8rpx;
}

.about-text text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
}

.about-version {
  font-size: 24rpx !important;
  color: rgba(255, 255, 255, 0.3) !important;
}

.about-desc {
  padding: 0 8rpx;
}

.about-desc text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1.8;
}

.about-para {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.about-signature {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1.6;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}
